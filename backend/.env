# Database
MONGODB_URL=mongodb://127.0.0.1:27017/?directConnection=true&serverSelectionTimeoutMS=2000&appName=mongosh+2.5.10
DATABASE_NAME=restaurant_saas

# JWT Settings
SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# App Settings
APP_NAME=DineFlow
APP_VERSION=1.0.0
DEBUG=True

# CORS
FRONTEND_URL=http://localhost:5173

# File Upload
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10485760

# OTP Settings
OTP_EXPIRE_MINUTES=5
